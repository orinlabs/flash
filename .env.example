# Copy to `.env` and fill in. See PLAN.md for Render / DB setup.
DATABASE_URL=postgresql://flash:flash@localhost:5432/flash

# Public URL of the API (open-tracking pixel + OAuth callbacks). On Render: flash-api service URL.
TRACKING_PUBLIC_BASE_URL=http://localhost:3000
# Optional salt for hashing client IPs on open events (defaults to a built-in value).
# TRACKING_IP_HASH_SALT=

RENDER_API_KEY=
RENDER_WORKFLOW_SLUG=

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5-mini
EXA_API_KEY=

# Sign-in codes via Resend. Add and verify donotreply.orinlabs.ai at https://resend.com/domains
RESEND_API_KEY=
# Optional; defaults to Flash <noreply@donotreply.orinlabs.ai>
# RESEND_FROM_EMAIL=
